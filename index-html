</tbody>
</table>

<div class="total">
<p>Total: Rp <span id="total">2200000</span></p>
<p>Sudah Dibayar: Rp <span id="bayar">0</span></p>
<p>Sisa: Rp <span id="sisa">2200000</span></p>
</div>

</div>


<script>

let sudah=0;

function bayar(tombol){

let baris=tombol.parentElement.parentElement;

if(tombol.innerHTML=="Belum"){

tombol.innerHTML="✔ Lunas";
baris.classList.add("lunas");
sudah += 200000;

}else{

tombol.innerHTML="Belum";
baris.classList.remove("lunas");
sudah -= 200000;

}

document.getElementById("bayar").innerHTML=
sudah.toLocaleString("id-ID");

document.getElementById("sisa").innerHTML=
(2200000-sudah).toLocaleString("id-ID");

}

</script>

</body>
</html>
