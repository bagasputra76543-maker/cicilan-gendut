<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Cicilan Gendut</title>

<style>
body{
    font-family:Arial,sans-serif;
    background:#f2f7f2;
    padding:20px;
}

.container{
    max-width:700px;
    margin:auto;
    background:white;
    padding:20px;
    border-radius:15px;
    box-shadow:0 5px 15px rgba(0,0,0,.15);
}

h2{
    text-align:center;
    color:#2e7d32;
}

table{
    width:100%;
    border-collapse:collapse;
}

th{
    background:#4CAF50;
    color:white;
}

th,td{
    padding:10px;
    border:1px solid #ddd;
    text-align:center;
}

button{
    padding:7px 12px;
    border:none;
    border-radius:8px;
    cursor:pointer;
    background:#ff9800;
    color:white;
}

.lunas{
    background:#e8f5e9;
    color:#777;
}

.lunas td{
    text-decoration:line-through;
}

.total{
    margin-top:20px;
    background:#4CAF50;
    color:white;
    padding:15px;
    border-radius:10px;
}
</style>
</head>

<body>

<div class="container">

<h2>Data Cicilan Gendut</h2>

<table>
<thead>
<tr>
<th>No</th>
<th>Bulan</th>
<th>Cicilan</th>
<th>Status</th>
</tr>
</thead>

<tbody id="data">

